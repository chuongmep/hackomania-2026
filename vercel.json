{
  "buildCommand": "npm run build",
  "outputDirectory": "front-end/pab-dashboard/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/user.html",
      "destination": "/user.html"
    },
    {
      "source": "/user",
      "destination": "/user.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
